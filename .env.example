# ============================================
# Startup Navigator — Environment Variables
# ============================================

# Application
APP_NAME=Startup Navigator
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (Neon PostgreSQL)
# Format: postgresql+asyncpg://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://neondb_owner:your_password@ep-example-123456.us-east-2.aws.neon.tech/startup_navigator?sslmode=require

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-64-char-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO

# AI Assistant
GEMINI_API_KEY=your_gemini_api_key_here

